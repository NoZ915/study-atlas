---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SUBJECTS } from '../data/subjects';
---

<BaseLayout
  title="學測知識庫"
  description="學測所有科目知識匯集，包含國文、英文、數學、生物、物理、地科、化學，附互動說明與自我測驗。"
>
  <!-- Hero -->
  <section
    style="background: linear-gradient(135deg, #0F2027 0%, #203A43 50%, #2C5364 100%)"
    class="relative overflow-hidden py-20 px-6 text-center"
  >
    <!-- Grid overlay -->
    <div
      class="absolute inset-0 opacity-[0.04]"
      style="background-image: repeating-linear-gradient(0deg, transparent, transparent 40px, #fff 40px, #fff 41px), repeating-linear-gradient(90deg, transparent, transparent 40px, #fff 40px, #fff 41px);"
    ></div>

    <div class="relative z-10 max-w-2xl mx-auto">
      <p class="text-xs tracking-[4px] font-semibold text-[#7DD3C0] mb-3 uppercase">
        台灣學測 · 全科目
      </p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4">
        學測知識庫
      </h1>
      <p class="text-base text-slate-400 leading-relaxed">
        從概念到解題，每個章節都有互動說明與自我測驗<br />
        選擇你要複習的科目，開始學習吧
      </p>
    </div>
  </section>

  <!-- Subjects Grid -->
  <main class="max-w-5xl mx-auto px-4 py-14">
    <h2 class="text-xl font-bold text-[var(--fg)] mb-8 text-center">選擇科目</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        SUBJECTS.map((subject) => {
          const totalSections = subject.chapters.reduce(
            (sum, ch) => sum + ch.sections.length,
            0
          );
          const readySections = subject.chapters.reduce(
            (sum, ch) => sum + ch.sections.filter((s) => s.ready).length,
            0
          );
          return (
            <a
              href={`/${subject.id}`}
              class="group relative rounded-2xl border overflow-hidden no-underline transition-all duration-200 hover:-translate-y-1 hover:shadow-lg"
              style={`border-color: ${subject.color}33; background: ${subject.light};`}
            >
              <!-- Color accent bar -->
              <div class="h-1.5" style={`background: ${subject.color};`} />

              <div class="p-6">
                <div class="flex items-start justify-between mb-3">
                  <span class="text-4xl">{subject.icon}</span>
                  <span
                    class="text-xs font-semibold px-2.5 py-1 rounded-full"
                    style={`background: ${subject.color}18; color: ${subject.accent};`}
                  >
                    {readySections > 0 ? `${readySections} 節可讀` : '即將上線'}
                  </span>
                </div>

                <h3 class="text-xl font-extrabold mb-0.5" style={`color: ${subject.accent};`}>
                  {subject.title}
                </h3>
                <p class="text-xs font-medium mb-3" style={`color: ${subject.accent}99;`}>
                  {subject.englishTitle}
                </p>
                <p class="text-sm leading-relaxed text-[var(--fg2)]">{subject.description}</p>

                <div
                  class="mt-4 flex items-center gap-1 text-sm font-semibold"
                  style={`color: ${subject.color};`}
                >
                  進入專區 →
                </div>
              </div>
            </a>
          );
        })
      }
    </div>
  </main>
</BaseLayout>
