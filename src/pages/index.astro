---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SUBJECTS } from "../data/subjects";

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Study Atlas"
  description="Just building stuff with AI. A small atlas for chapter notes, review paths, and learning maps."
>
  <section
    class="relative overflow-hidden px-6 py-20 text-center"
    style="background: linear-gradient(135deg, #0F2027 0%, #203A43 50%, #2C5364 100%)"
  >
    <div
      class="absolute inset-0 opacity-[0.04]"
      style="background-image: repeating-linear-gradient(0deg, transparent, transparent 40px, #fff 40px, #fff 41px), repeating-linear-gradient(90deg, transparent, transparent 40px, #fff 40px, #fff 41px);"
    ></div>

    <div class="relative z-10 mx-auto max-w-2xl">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[4px] text-[#7DD3C0]">
        Just building stuff with AI
      </p>
      <h1 class="mb-4 text-4xl font-extrabold leading-tight text-white md:text-5xl">
        Study Atlas
      </h1>
      <p class="text-base leading-relaxed text-slate-400">
        A small workspace for chapter notes, concept maps, formulas, and review paths.
        <br />
        Built as a compact learning atlas rather than a traditional subject portal.
      </p>
    </div>
  </section>

  <main class="mx-auto max-w-5xl px-4 py-14">
    <h2 class="mb-8 text-center text-xl font-bold text-[var(--fg)]">Browse Subjects</h2>
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        SUBJECTS.map((subject) => {
          const readySections = subject.chapters.reduce(
            (sum, ch) => sum + ch.sections.filter((s) => s.ready).length,
            0,
          );

          return (
            <a
              href={`${baseUrl}${subject.id}`}
              class="group relative overflow-hidden rounded-2xl border no-underline transition-all duration-200 hover:-translate-y-1 hover:shadow-lg"
              style={`border-color: ${subject.color}33; background: ${subject.light};`}
            >
              <div class="h-1.5" style={`background: ${subject.color};`} />

              <div class="p-6">
                <div class="mb-3 flex items-start justify-between">
                  <span class="text-4xl">{subject.icon}</span>
                  <span
                    class="rounded-full px-2.5 py-1 text-xs font-semibold"
                    style={`background: ${subject.color}18; color: ${subject.accent};`}
                  >
                    {readySections > 0 ? `${readySections} ready` : "draft"}
                  </span>
                </div>

                <h3 class="mb-0.5 text-xl font-extrabold" style={`color: ${subject.accent};`}>
                  {subject.title}
                </h3>
                <p class="mb-3 text-xs font-medium" style={`color: ${subject.accent}99;`}>
                  {subject.englishTitle}
                </p>
                <p class="text-sm leading-relaxed text-[var(--fg2)]">{subject.description}</p>

                <div class="mt-4 flex items-center gap-1 text-sm font-semibold" style={`color: ${subject.color};`}>
                  Open subject →
                </div>
              </div>
            </a>
          );
        })
      }
    </div>
  </main>
</BaseLayout>
