---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SUBJECTS, getSubject, getSection, getChapterForSection } from '../../data/subjects';
import CircuitReview from '../../components/sections/physics-4-0/CircuitReview';
import MagneticEffect from '../../components/sections/physics-4-1/MagneticEffect';
import ElectromagneticInduction from '../../components/sections/physics-4-2/ElectromagneticInduction';
import CellStructure from '../../components/sections/biology-1-1/CellStructure';
import VocabReview from '../../components/sections/english-1-1/VocabReview';
import NumberAndExpression from '../../components/sections/math-1-1/NumberAndExpression';

// Generate all section routes
export function getStaticPaths() {
  const paths = [];
  for (const subject of SUBJECTS) {
    for (const chapter of subject.chapters) {
      for (const section of chapter.sections) {
        paths.push({
          params: { subject: subject.id, section: section.id },
        });
      }
    }
  }
  return paths;
}

const { subject: subjectId, section: sectionId } = Astro.params;
const subject = getSubject(subjectId)!;
const section = getSection(subjectId, sectionId)!;
const chapter = getChapterForSection(subjectId, sectionId)!;

// Component registry — add new section components here
const componentKey = `${subjectId}/${sectionId}`;
const hasComponent =
  componentKey === 'physics/4-0' ||
  componentKey === 'physics/4-1' ||
  componentKey === 'physics/4-2' ||
  componentKey === 'biology/1-1' ||
  componentKey === 'english/1-1' ||
  componentKey === 'math/1-1';
---

<BaseLayout
  title={`${section.title} | ${subject.title} | 學測知識庫`}
  description={section.description}
>
  <!-- Section hero -->
  <section
    class="py-10 px-6 text-center"
    style={`background: linear-gradient(135deg, ${subject.accent} 0%, ${subject.color} 100%);`}
  >
    <div class="max-w-3xl mx-auto">
      <p class="text-xs tracking-widest font-semibold text-white/60 mb-2 uppercase">
        {subject.title} · {chapter.title}
      </p>
      <h1 class="text-3xl font-extrabold text-white mb-2">{section.title}</h1>
      <p class="text-sm text-white/75 leading-relaxed max-w-lg mx-auto">{section.description}</p>
      {section.tags && (
        <div class="flex justify-center gap-2 mt-4 flex-wrap">
          {section.tags.map((tag) => (
            <span class="text-xs px-3 py-1 rounded-full bg-white/20 text-white font-medium">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Breadcrumb -->
  <div class="max-w-3xl mx-auto px-4 py-3 text-sm text-[var(--fg2)]">
    <a href="/" class="hover:underline">首頁</a>
    <span class="mx-2">›</span>
    <a href={`/${subject.id}`} class="hover:underline">{subject.title}</a>
    <span class="mx-2">›</span>
    <span class="font-semibold text-[var(--fg)]">{section.id} {section.title}</span>
  </div>

  <!-- Content -->
  <main class="max-w-3xl mx-auto px-4 pb-16">
    {hasComponent ? (
      componentKey === 'physics/4-0' ? <CircuitReview client:load /> :
      componentKey === 'physics/4-1' ? <MagneticEffect client:load /> :
      componentKey === 'physics/4-2' ? <ElectromagneticInduction client:load /> :
      componentKey === 'math/1-1' ? <NumberAndExpression client:load /> :
      componentKey === 'english/1-1' ? <VocabReview client:load /> :
      <CellStructure client:load />
    ) : (
      <!-- Placeholder for sections not yet written -->
      <div class="rounded-2xl border border-dashed border-[var(--border)] bg-white p-16 text-center">
        <div class="text-5xl mb-4">{subject.icon}</div>
        <h2 class="text-xl font-bold text-[var(--fg)] mb-2">內容準備中</h2>
        <p class="text-sm text-[var(--fg2)] leading-relaxed">
          這個小節的互動內容正在製作中，敬請期待！<br />
          目前可以先回到{subject.title}專區查看其他已上線的章節。
        </p>
        <a
          href={`/${subject.id}`}
          class="inline-block mt-6 px-6 py-2.5 rounded-xl text-sm font-semibold text-white no-underline"
          style={`background: ${subject.color};`}
        >
          ← 回到{subject.title}專區
        </a>
      </div>
    )}
  </main>
</BaseLayout>
