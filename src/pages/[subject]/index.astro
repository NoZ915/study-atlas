---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SUBJECTS, getSubject } from '../../data/subjects';
import MathOverview from '../../components/subject/MathOverview.astro';

export function getStaticPaths() {
  return SUBJECTS.map((subject) => ({
    params: { subject: subject.id },
  }));
}

const { subject: subjectId } = Astro.params;
const subject = getSubject(subjectId)!;
---

<BaseLayout
  title={`${subject.title} | 學測知識庫`}
  description={`學測${subject.title}（${subject.englishTitle}）章節總覽。${subject.description}`}
>
  <!-- Subject Header -->
  <section
    class="py-14 px-6 text-center relative overflow-hidden"
    style={`background: linear-gradient(135deg, ${subject.accent} 0%, ${subject.color} 100%);`}
  >
    <div
      class="absolute inset-0 opacity-[0.06]"
      style="background-image: repeating-linear-gradient(0deg, transparent, transparent 40px, #fff 40px, #fff 41px), repeating-linear-gradient(90deg, transparent, transparent 40px, #fff 40px, #fff 41px);"
    ></div>
    <div class="relative z-10">
      <span class="text-6xl mb-4 block">{subject.icon}</span>
      <h1 class="text-4xl font-extrabold text-white mb-1">{subject.title}</h1>
      <p class="text-base text-white/70 mb-2">{subject.englishTitle}</p>
      <p class="text-sm text-white/80 max-w-lg mx-auto">{subject.description}</p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <div class="max-w-3xl mx-auto px-4 py-3 text-sm text-[var(--fg2)]">
    <a href="/" class="hover:underline">首頁</a>
    <span class="mx-2">›</span>
    <span class="font-semibold text-[var(--fg)]">{subject.title}</span>
  </div>

  <!-- Chapters -->
  <main class="max-w-3xl mx-auto px-4 pb-16">
    {subject.id === 'math' && <MathOverview />}

    {
      subject.chapters.map((chapter) => (
        <div class="mb-10">
          <h2 class="text-lg font-bold text-[var(--fg)] mb-4 flex items-center gap-2">
            <span
              class="w-1.5 h-6 rounded-full inline-block"
              style={`background: ${subject.color};`}
            />
            {chapter.title}
          </h2>

          <div class="flex flex-col gap-3">
            {chapter.sections.map((section) => (
              <a
                href={section.ready ? `/${subject.id}/${section.id}` : undefined}
                class={[
                  'rounded-xl border p-5 transition-all duration-150 no-underline',
                  section.ready
                    ? 'hover:-translate-y-0.5 hover:shadow-md cursor-pointer'
                    : 'opacity-60 cursor-not-allowed',
                ].join(' ')}
                style={`border-color: ${subject.color}33; background: ${subject.light};`}
              >
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <span
                        class="text-xs font-bold px-2 py-0.5 rounded"
                        style={`background: ${subject.color}20; color: ${subject.accent};`}
                      >
                        {section.id}
                      </span>
                      {section.ready && (
                        <span class="text-xs font-semibold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded">
                          ✓ 可讀
                        </span>
                      )}
                    </div>
                    <h3 class="font-bold text-base" style={`color: ${subject.accent};`}>
                      {section.title}
                    </h3>
                    <p class="text-sm text-[var(--fg2)] mt-1 leading-relaxed">
                      {section.description}
                    </p>
                    {section.tags && (
                      <div class="flex flex-wrap gap-1.5 mt-2">
                        {section.tags.map((tag) => (
                          <span
                            class="text-xs px-2 py-0.5 rounded-full"
                            style={`background: ${subject.color}14; color: ${subject.accent};`}
                          >
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                  {section.ready && (
                    <span class="text-xl mt-1" style={`color: ${subject.color};`}>
                      →
                    </span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </main>
</BaseLayout>
