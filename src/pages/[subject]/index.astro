---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SUBJECTS, getSubject } from "../../data/subjects";
import MathOverview from "../../components/subject/MathOverview.astro";

export function getStaticPaths() {
  return SUBJECTS.map((subject) => ({
    params: { subject: subject.id },
  }));
}

const { subject: subjectId } = Astro.params;
const subject = getSubject(subjectId)!;
const baseUrl = import.meta.env.BASE_URL;
const homeHref = baseUrl;
---

<BaseLayout
  title={`${subject.title} | 學測知識庫`}
  description={`學測${subject.title}整理頁，包含章節導覽與重點內容。`}
>
  <section
    class="relative overflow-hidden px-6 py-14 text-center"
    style={`background: linear-gradient(135deg, ${subject.accent} 0%, ${subject.color} 100%);`}
  >
    <div
      class="absolute inset-0 opacity-[0.06]"
      style="background-image: repeating-linear-gradient(0deg, transparent, transparent 40px, #fff 40px, #fff 41px), repeating-linear-gradient(90deg, transparent, transparent 40px, #fff 40px, #fff 41px);"
    ></div>
    <div class="relative z-10">
      <span class="mb-4 block text-6xl">{subject.icon}</span>
      <h1 class="mb-1 text-4xl font-extrabold text-white">{subject.title}</h1>
      <p class="mb-2 text-base text-white/70">{subject.englishTitle}</p>
      <p class="mx-auto max-w-lg text-sm text-white/80">{subject.description}</p>
    </div>
  </section>

  <div class="mx-auto max-w-3xl px-4 py-3 text-sm text-[var(--fg2)]">
    <a href={homeHref} class="hover:underline">首頁</a>
    <span class="mx-2">/</span>
    <span class="font-semibold text-[var(--fg)]">{subject.title}</span>
  </div>

  <main class="mx-auto max-w-3xl px-4 pb-16">
    {subject.id === "math" && <MathOverview />}

    {
      subject.chapters.map((chapter) => (
        <div class="mb-10">
          <h2 class="mb-4 flex items-center gap-2 text-lg font-bold text-[var(--fg)]">
            <span class="inline-block h-6 w-1.5 rounded-full" style={`background: ${subject.color};`} />
            {chapter.title}
          </h2>

          <div class="flex flex-col gap-3">
            {chapter.sections.map((section) => (
              <a
                href={section.ready ? `${baseUrl}${subject.id}/${section.id}` : undefined}
                class={[
                  "rounded-xl border p-5 no-underline transition-all duration-150",
                  section.ready ? "cursor-pointer hover:-translate-y-0.5 hover:shadow-md" : "cursor-not-allowed opacity-60",
                ].join(" ")}
                style={`border-color: ${subject.color}33; background: ${subject.light};`}
              >
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0 flex-1">
                    <div class="mb-1 flex items-center gap-2">
                      <span
                        class="rounded px-2 py-0.5 text-xs font-bold"
                        style={`background: ${subject.color}20; color: ${subject.accent};`}
                      >
                        {section.id}
                      </span>
                      {section.ready && (
                        <span class="rounded bg-emerald-50 px-2 py-0.5 text-xs font-semibold text-emerald-600">
                          已完成
                        </span>
                      )}
                    </div>
                    <h3 class="text-base font-bold" style={`color: ${subject.accent};`}>
                      {section.title}
                    </h3>
                    <p class="mt-1 text-sm leading-relaxed text-[var(--fg2)]">{section.description}</p>
                    {section.tags && (
                      <div class="mt-2 flex flex-wrap gap-1.5">
                        {section.tags.map((tag) => (
                          <span
                            class="rounded-full px-2 py-0.5 text-xs"
                            style={`background: ${subject.color}14; color: ${subject.accent};`}
                          >
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                  {section.ready && (
                    <span class="mt-1 text-xl" style={`color: ${subject.color};`}>
                      →
                    </span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </main>
</BaseLayout>
