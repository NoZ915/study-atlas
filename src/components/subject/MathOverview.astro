            <div class="text-[11px] font-bold tracking-[0.18em] text-white/60">TOTAL</div>
            <div class="mt-1 text-2xl font-extrabold">{questStats.total}</div>
            <div class="text-xs text-white/70">全部節點</div>
          </div>
          <div class="rounded-2xl border border-white/12 bg-white/8 px-4 py-3">
            <div class="text-[11px] font-bold tracking-[0.18em] text-white/60">MAIN</div>
            <div class="mt-1 text-2xl font-extrabold">{questStats.main}</div>
            <div class="text-xs text-white/70">主線任務</div>
          </div>
          <div class="rounded-2xl border border-white/12 bg-white/8 px-4 py-3">
            <div class="text-[11px] font-bold tracking-[0.18em] text-white/60">SIDE</div>
            <div class="mt-1 text-2xl font-extrabold">{questStats.side}</div>
            <div class="text-xs text-white/70">支線任務</div>
          </div>
          <div class="rounded-2xl border border-white/12 bg-white/8 px-4 py-3">
            <div class="text-[11px] font-bold tracking-[0.18em] text-white/60">CROSS</div>
            <div class="mt-1 text-2xl font-extrabold">{questStats.cross}</div>
            <div class="text-xs text-white/70">交會任務</div>
          </div>
        </div>
      </div>

      <div class="mt-5 flex flex-wrap gap-2">
        {Object.values(questTypeMeta).map((meta) => (
          <div class="rounded-full border border-white/10 px-3 py-1 text-xs font-bold text-white" style={`background:${meta.color}33;`}>
            {meta.label}
          </div>
        ))}
      </div>
    </div>

    <div class="space-y-6">
      {questBoardSections.map((section) => (
        <section>
          <div class="mb-3 flex items-end justify-between gap-3">
            <div>
              <h4 class="text-base font-extrabold text-[#2f2420]">{section.title}</h4>
              <p class="mt-1 text-sm text-[#7a655f]">{section.summary}</p>
            </div>
            <div class="rounded-full bg-[#fff4ee] px-3 py-1 text-xs font-bold text-[#b33d34]">
              {section.lines.reduce((sum, line) => sum + line.steps.length, 0)} 節點
            </div>
          </div>

          <div class="grid gap-4 xl:grid-cols-2">
            {section.lines.map((line) => (
              <details class="group overflow-hidden rounded-[26px] border border-[#eadfd8] bg-white shadow-[0_12px_36px_rgba(92,58,40,0.08)]">
                <summary
                  class="relative cursor-pointer list-none overflow-hidden px-5 py-5"
                  style={`background:linear-gradient(135deg, ${line.tone.bg} 0%, #fffaf7 68%, #ffffff 100%);`}
                >
                  <div class="absolute right-0 top-0 h-24 w-24 rounded-full blur-2xl" style={`background:${line.tone.color}18;`}></div>
                  <div class="relative flex items-start justify-between gap-3">
                    <div class="min-w-0">
                      <div class="text-[11px] font-bold tracking-[0.2em]" style={`color:${line.tone.color};`}>MISSION LINE</div>
                      <div class="mt-1 text-lg font-extrabold text-[#2f2420]">{line.title}</div>
                      <p class="mt-2 text-sm leading-6 text-[#6f5b54]">{line.summary}</p>
                    </div>
                    <div class="shrink-0 rounded-2xl border border-white/70 bg-white/80 px-3 py-2 text-right shadow-sm">
                      <div class="text-xs font-bold" style={`color:${line.tone.color};`}>STAGE</div>
                      <div class="mt-1 text-xl font-extrabold text-[#2f2420]">{line.steps.length}</div>
                    </div>
                  </div>
                </summary>

                <div class="border-t border-[#f1e6df] bg-[#fffdfb] px-5 py-5">
                  <div class="space-y-3">
                    {line.steps.map((step, index) => {
                      const questMeta = questTypeMeta[step.questType];
                      return (
                        <div class="flex items-stretch gap-3">
                          <div class="flex w-10 flex-col items-center">
                            <div
                              class="flex h-10 w-10 items-center justify-center rounded-full border-2 bg-white text-xs font-extrabold shadow-sm"
                              style={`border-color:${line.tone.color}45; color:${line.tone.color}; box-shadow:0 0 0 6px ${line.tone.color}12;`}
                            >
                              {step.order}
                            </div>
                            {index < line.steps.length - 1 && (
                              <div class="mt-2 h-full min-h-10 w-[2px] rounded-full" style={`background:linear-gradient(180deg, ${line.tone.color}66 0%, ${line.tone.color}18 100%);`}></div>
                            )}
                          </div>

                          <button
                            type="button"
                            data-item-modal={step.id}
                            class="min-w-0 flex-1 rounded-[22px] border border-[#efe4de] bg-white px-4 py-4 text-left transition-all hover:-translate-y-0.5 hover:bg-[#fff7f1] hover:shadow-[0_12px_30px_rgba(108,71,52,0.10)]"
                          >
                            <div class="flex flex-wrap items-start justify-between gap-2">
                              <div class="min-w-0">
                                <div class="text-xs font-extrabold" style={`color:${line.tone.color};`}>{step.id}</div>
                                <div class="mt-1 text-base font-bold text-[#3f332f]">{step.title}</div>
                              </div>
                              <span class="rounded-full px-2.5 py-1 text-[11px] font-bold" style={`background:${questMeta.bg}; color:${questMeta.color};`}>
                                {questMeta.label}
                              </span>
                            </div>

                            <div class="mt-2 text-sm leading-6 text-[#7a655f]">{step.note}</div>

                            <div class="mt-3 flex flex-wrap gap-2">
                              {step.prerequisites.length > 0 ? (
                                step.prerequisites.map((prerequisite) => (
                                  <span class="rounded-full border border-[#f0e4de] bg-[#fffaf7] px-2.5 py-1 text-[11px] font-bold text-[#8b6d63]">
                                    前置 {prerequisite.id}
                                  </span>
                                ))
                              ) : (
                                <span class="rounded-full bg-[#fde8e7] px-2.5 py-1 text-[11px] font-bold text-[#b33d34]">起始節點</span>
                              )}

                              {step.unlocks.length > 0 && (
                                <span class="rounded-full px-2.5 py-1 text-[11px] font-bold" style={`background:${line.tone.bg}; color:${line.tone.color};`}>
                                  解鎖 {step.unlocks.length} 個後續
                                </span>
                              )}
                            </div>
                          </button>
                        </div>
                      );
                    })}
                  </div>
                </div>
              </details>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>

  <dialog id="math-dialog" class="m-auto w-[min(760px,calc(100vw-2rem))] rounded-[28px] border border-[#eadfd8] p-0 text-left shadow-[0_24px_80px_rgba(55,33,24,0.22)] backdrop:bg-[rgba(34,24,20,0.38)]">
    <div class="border-b border-[#f1e4de] bg-[#fff8f3] px-6 py-4">
      <div class="flex items-start justify-between gap-4">
        <div>
          <div id="math-dialog-kicker" class="text-xs font-bold tracking-[0.24em] text-[#b33d34]"></div>
          <h3 id="math-dialog-title" class="mt-1 text-xl font-extrabold text-[#2f2420]"></h3>
        </div>
        <button type="button" data-dialog-close class="rounded-full bg-white px-3 py-1 text-sm font-bold text-[#8b6d63] ring-1 ring-[#eadfd8]">
          關閉
        </button>
      </div>
    </div>
    <div id="math-dialog-body" class="max-h-[70vh] overflow-y-auto px-6 py-5"></div>
  </dialog>

  <script type="application/json" id="math-axis-data" set:html={axisModalJson}></script>
  <script type="application/json" id="math-item-data" set:html={itemModalJson}></script>
</section>

<script>
  const root = document.getElementById('math-overview');

  if (root) {
    const tabButtons = Array.from(root.querySelectorAll('[data-tab-trigger]'));
    const tabPanels = Array.from(root.querySelectorAll('[data-tab-panel]'));
    const dialog = root.querySelector('#math-dialog');
    const dialogKicker = root.querySelector('#math-dialog-kicker');
    const dialogTitle = root.querySelector('#math-dialog-title');
    const dialogBody = root.querySelector('#math-dialog-body');
    const closeButton = root.querySelector('[data-dialog-close]');
    const axisData = JSON.parse(root.querySelector('#math-axis-data')?.textContent ?? '{}');
    const itemData = JSON.parse(root.querySelector('#math-item-data')?.textContent ?? '{}');

    const setActiveTab = (tab) => {
      tabButtons.forEach((button) => {
        const active = button.getAttribute('data-tab') === tab;
        button.classList.toggle('bg-[#b33d34]', active);
        button.classList.toggle('text-white', active);
        button.classList.toggle('bg-white', !active);
        button.classList.toggle('text-[#8b6d63]', !active);
        button.classList.toggle('ring-1', !active);
        button.classList.toggle('ring-[#eadfd8]', !active);
      });

      tabPanels.forEach((panel) => {
        panel.classList.toggle('hidden', panel.getAttribute('data-tab-panel') !== tab);
      });
    };

    const openDialog = (kicker, title, html) => {
      if (!(dialog && dialogKicker && dialogTitle && dialogBody)) return;
      dialogKicker.textContent = kicker;
      dialogTitle.textContent = title;
      dialogBody.innerHTML = html;
      dialog.showModal();
    };

    const renderAxisDialog = (axisId) => {
      const axis = axisData[axisId];
      if (!axis) return;

      const html = `
        <div class="rounded-[24px] border p-5" style="border-color:${axis.color}26; background:${axis.bg};">
          <div class="flex items-center justify-between gap-3">
            <div class="text-lg font-extrabold" style="color:${axis.color};">
              ${axis.label}
            </div>
            <div class="rounded-full bg-white/80 px-3 py-1 text-xs font-bold" style="color:${axis.color};">
              ${axis.items.length} 小節
            </div>
          </div>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            ${axis.items
              .map(
                (item) => `
                  <button type="button" data-item-modal="${item.id}" class="rounded-xl border border-[#f0e4de] bg-[#fffaf7] px-3 py-2 text-left transition-colors hover:bg-[#fff4ee]">
                    <div class="text-xs font-extrabold" style="color:${axis.color}">${item.id}</div>
                    <div class="mt-1 text-sm font-semibold text-[#584742]">${item.title}</div>
                  </button>
                `,
              )
              .join('')}
          </div>
        </div>
      `;

      openDialog('主軸分類', axis.label, html);
    };

    const renderItemDialog = (itemId) => {
      const item = itemData[itemId];
      if (!item) return;

      const related = item.related.map((relatedId) => axisData[relatedId]).filter(Boolean);
      const questTypeMeta = {
        start: { label: '起始任務', color: '#B33D34', bg: '#FDE8E7' },
        main: { label: '主線任務', color: '#1B6FA0', bg: '#E8F4FD' },
        side: { label: '支線任務', color: '#7B3DB5', bg: '#F3EAFC' },
        cross: { label: '交會任務', color: '#2F7A6B', bg: '#E7F6F2' },
      };
      const quest = item.quest;
      const questMeta = quest ? questTypeMeta[quest.questType] : null;

      const html = `
        ${quest ? `
          <section class="mb-4 rounded-2xl border border-[#efe4de] bg-[#fffaf7] p-4">
            <div class="flex flex-wrap items-center gap-2">
              <div class="text-sm font-extrabold text-[#b33d34]">任務地圖</div>
              ${questMeta ? `
                <span class="rounded-full px-3 py-1 text-xs font-bold" style="background:${questMeta.bg}; color:${questMeta.color};">
                  ${questMeta.label}
                </span>
              ` : ''}
            </div>
            <div class="mt-2 text-base font-bold text-[#3f332f]">${quest.lineTitle}</div>
            <div class="mt-1 text-sm leading-6 text-[#6a5953]">${quest.lineSummary}</div>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              <div class="rounded-2xl border border-[#f0e4de] bg-white p-3">
                <div class="text-xs font-extrabold text-[#8b6d63]">前置任務</div>
                <div class="mt-2 flex flex-wrap gap-2">
                  ${quest.prerequisites.length > 0
                    ? quest.prerequisites.map((prerequisite) => `
                      <span class="rounded-full bg-[#f6ebe5] px-2.5 py-1 text-xs font-bold text-[#8b6d63]">
                        ${prerequisite.id}
                      </span>
                    `).join('')
                    : '<span class="rounded-full bg-[#fff4ee] px-2.5 py-1 text-xs font-bold text-[#b33d34]">無前置</span>'}
                </div>
              </div>
              <div class="rounded-2xl border border-[#f0e4de] bg-white p-3">
                <div class="text-xs font-extrabold text-[#8b6d63]">解鎖後續</div>
                <div class="mt-2 flex flex-wrap gap-2">
                  ${quest.unlocks.length > 0
                    ? quest.unlocks.map((unlock) => `
                      <span class="rounded-full bg-[#f6ebe5] px-2.5 py-1 text-xs font-bold text-[#8b6d63]">
                        ${unlock.id}
                      </span>
                    `).join('')
                    : '<span class="rounded-full bg-[#f8f1ed] px-2.5 py-1 text-xs font-bold text-[#8b6d63]">目前沒有後續節點</span>'}
                </div>
              </div>
            </div>
          </section>
        ` : ''}
        ${related.length > 0 ? `
          <section class="mb-4 rounded-2xl border border-[#efe4de] bg-[#fffaf7] p-4">
            <div class="text-sm font-extrabold text-[#b33d34]">副關聯</div>
            <div class="mt-2 flex flex-wrap gap-2">
              ${related
                .map(
                  (axis) => `
                    <span class="rounded-full px-3 py-1 text-sm font-bold" style="background:${axis.bg}; color:${axis.color};">
                      ${axis.label}
                    </span>
                  `,
                )
                .join('')}
            </div>
          </section>
        ` : ''}
        ${item.paths
          .map(
            (path) => `
              <section class="mb-4 rounded-2xl border border-[#efe4de] bg-[#fffaf7] p-4">
                <div class="text-sm font-extrabold text-[#b33d34]">${path.title}</div>
                <div class="mt-3 space-y-3">
                  ${path.steps
                    .map(
                      (step, index) => `
                        <div class="flex items-start gap-3">
                          <div class="flex min-w-0 flex-1 items-start gap-3 rounded-2xl border px-4 py-3 ${
                            index === path.activeIndex ? 'border-[#e2574c] bg-[#fff1eb]' : 'border-[#f0e4de] bg-white'
                          }">
                            <div class="mt-0.5 rounded-full px-2 py-1 text-xs font-extrabold ${index === path.activeIndex ? 'bg-[#e2574c] text-white' : 'bg-[#fde8e7] text-[#b33d34]'}">
                              ${index + 1}
                            </div>
                            <div>
                              <div class="font-semibold text-[#3f332f]">${step.id} ${step.title}</div>
                              <div class="mt-1 text-sm leading-6 text-[#6a5953]">${step.note}</div>
                            </div>
                          </div>
                          ${index < path.steps.length - 1 ? '<div class="pt-4 text-sm font-extrabold text-[#c47a35]">→</div>' : ''}
                        </div>
                      `,
                    )
                    .join('')}
                </div>
              </section>
            `,
          )
          .join('')}
      `;

      openDialog(item.chapter, `${itemId} ${item.title}`, html);
    };

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const tab = button.getAttribute('data-tab');
        if (tab) setActiveTab(tab);
      });
    });

    root.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      const axisButton = target.closest('[data-axis-modal]');
      if (axisButton instanceof HTMLElement) {
        const axisId = axisButton.getAttribute('data-axis-modal');
        if (axisId) renderAxisDialog(axisId);
        return;
      }

      const itemButton = target.closest('[data-item-modal]');
      if (itemButton instanceof HTMLElement) {
        const itemId = itemButton.getAttribute('data-item-modal');
        if (itemId) renderItemDialog(itemId);
      }
    });

    closeButton?.addEventListener('click', () => dialog?.close());
    dialog?.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });

    setActiveTab('book');
  }
</script>
