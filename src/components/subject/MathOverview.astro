const chapterAxisMap = new Map<string, string[]>();
for (const book of books) {
  for (const chapter of book.chapters) {
    const axesForChapter = Array.from(
      new Set(chapter.items.flatMap((item) => [itemMeta[item.id as keyof typeof itemMeta].primary, ...itemMeta[item.id as keyof typeof itemMeta].related])),
    );
    chapterAxisMap.set(chapter.id, axesForChapter);
  }
}

const booksWithAxes = books.map((book) => ({
  ...book,
  chapters: book.chapters.map((chapter) => ({
    ...chapter,
    axes: chapterAxisMap.get(chapter.id) ?? [],
  })),
}));

const axisGroups = axes.map((axis) => ({
  ...axis,
  items: books
    .flatMap((book) =>
      book.chapters.flatMap((chapter) =>
        chapter.items
          .filter((item) => itemMeta[item.id as keyof typeof itemMeta].primary === axis.id)
          .map((item) => ({
            ...item,
            chapter: chapter.title,
            book: book.label,
            reason: itemMeta[item.id as keyof typeof itemMeta].reason,
          })),
      ),
    ),
}));

