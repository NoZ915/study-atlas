    ],
  },
] as const;

const questStepIndex = new Map(
  questLines.flatMap((line) =>
    line.steps.map((step) => [
      step.id,
      {
        ...step,
        lineId: line.id,
        lineTitle: line.title,
        lineSummary: line.summary,
        tone: line.tone,
      },
    ]),
  ),
);

const unlockMap = new Map<string, string[]>();
for (const line of questLines) {
  for (const step of line.steps) {
    unlockMap.set(step.id, []);
  }
}
for (const line of questLines) {
  for (const step of line.steps) {
    step.prerequisites.forEach((prerequisiteId) => {
      const unlocks = unlockMap.get(prerequisiteId) ?? [];
      unlocks.push(step.id);
      unlockMap.set(prerequisiteId, unlocks);
    });
  }
}

const questLinesExpanded = questLines.map((line) => ({
  ...line,
  steps: line.steps.map((step) => ({
    ...stepLookup.get(step.id)!,
    order: step.order,
    note: step.note,
    questType: step.questType,
    prerequisites: step.prerequisites.map((id) => stepLookup.get(id)!),
    unlocks: (unlockMap.get(step.id) ?? []).map((id) => stepLookup.get(id)!),
  })),
}));

const questStats = {
  total: questLinesExpanded.reduce((sum, line) => sum + line.steps.length, 0),
  start: questLinesExpanded.flatMap((line) => line.steps).filter((step) => step.questType === 'start').length,
  main: questLinesExpanded.flatMap((line) => line.steps).filter((step) => step.questType === 'main').length,
  side: questLinesExpanded.flatMap((line) => line.steps).filter((step) => step.questType === 'side').length,
  cross: questLinesExpanded.flatMap((line) => line.steps).filter((step) => step.questType === 'cross').length,
};

const questBoardSections = [
  {
    id: 'start',
    title: '起始區',
    summary: '先把底層運算和基本觀念點亮，後面大部分路線才會解鎖。',
    lines: questLinesExpanded.filter((line) => line.id === 'start-zone'),
  },
  {
    id: 'main',
    title: '主線區',
    summary: '核心知識線，建議把 A 到 D 先打通，再回頭補矩陣線。',
    lines: questLinesExpanded.filter((line) => ['main-a', 'main-b', 'main-c', 'main-d'].includes(line.id)),
  },
  {
    id: 'late',
    title: '後期解鎖',
    summary: '矩陣與線性轉換比較像後期支援職業，和向量、幾何交會最深。',
    lines: questLinesExpanded.filter((line) => line.id === 'main-e'),
  },
  {
    id: 'side',
    title: '支線區',
    summary: '可以和主線並行練，適合穿插複習，不需要完全等主線結束才開始。',
    lines: questLinesExpanded.filter((line) => ['side-f', 'side-g', 'side-h'].includes(line.id)),
  },
] as const;

const axisModalData = Object.fromEntries(
  axisGroups.map((group) => [
    group.id,
    {
      label: group.label,
      color: group.color,
      bg: group.bg,
      items: group.items,
    },
  ]),
);

const itemModalData: Record<
  string,
  {
    title: string;
    chapter: string;
    primary: string;
    related: string[];
    quest?: {
      lineTitle: string;
      lineSummary: string;
      questType: keyof typeof questTypeMeta;
      prerequisites: { id: string; title: string }[];
      unlocks: { id: string; title: string }[];
    };
    paths: { title: string; steps: { id: string; title: string; note: string }[]; activeIndex: number }[];
  }
> = {};

for (const [id, meta] of Object.entries(itemMeta)) {
  const step = stepLookup.get(id)!;
  itemModalData[id] = {
    title: step.title,
    chapter: meta.chapter,
    primary: meta.primary,
    related: meta.related,
    quest: undefined,
    paths: [],
  };
}

for (const [id, quest] of questStepIndex.entries()) {
  itemModalData[id].quest = {
    lineTitle: quest.lineTitle,
    lineSummary: quest.lineSummary,
    questType: quest.questType,
    prerequisites: quest.prerequisites.map((prerequisiteId) => {
      const prerequisite = stepLookup.get(prerequisiteId)!;
      return { id: prerequisite.id, title: prerequisite.title };
    }),
    unlocks: (unlockMap.get(id) ?? []).map((unlockId) => {
      const unlock = stepLookup.get(unlockId)!;
      return { id: unlock.id, title: unlock.title };
    }),
  };
}

for (const path of themePathsExpanded) {
  path.steps.forEach((step, index) => {
    itemModalData[step.id].paths.push({
      title: path.title,
      steps: path.steps.map((pathStep) => ({ id: pathStep.id, title: pathStep.title, note: pathStep.note })),
      activeIndex: index,
    });
  });
}

const axisModalJson = JSON.stringify(axisModalData);
const itemModalJson = JSON.stringify(itemModalData);
