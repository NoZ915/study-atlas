---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
}

const {
  title,
  description = "Study Atlas is a small learning workspace for notes, maps, and chapter-based review.",
  ogTitle,
} = Astro.props;

const siteName = "Study Atlas";
const siteTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;
const baseUrl = import.meta.env.BASE_URL;
const homeHref = baseUrl;
const faviconHref = `${baseUrl}favicon.svg`;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href={faviconHref} type="image/svg+xml" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{siteTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle ?? siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="zh_TW" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="sticky top-0 z-50 border-b border-[var(--border)] bg-white/90 backdrop-blur">
      <div class="mx-auto flex h-14 max-w-5xl items-center justify-between px-4">
        <a href={homeHref} class="flex items-center gap-2 font-bold text-[var(--fg)] no-underline">
          <span class="text-xl">🧭</span>
          <span class="text-base leading-tight">
            Study <span class="text-[var(--accent)]">Atlas</span>
          </span>
        </a>
        <div class="flex items-center gap-1 text-sm">
          <a href={homeHref} class="rounded-lg px-3 py-1.5 text-[var(--fg2)] transition-colors hover:bg-gray-100">
            Home
          </a>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="mt-16 border-t border-[var(--border)] py-10 text-center text-xs text-[var(--fg2)]">
      Study Atlas · Notes, maps, and review paths
    </footer>
  </body>
</html>
